<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.5.xsd">

    <changeSet id="1" author="laganga3pelos">
        <createTable tableName="categorias">
            <column name="id" type="BIGINT" autoIncrement="true"><constraints primaryKey="true"/></column>
            <column name="nombre" type="VARCHAR(255)"/>
        </createTable>

        <createTable tableName="componentes">
            <column name="id" type="BIGINT" autoIncrement="true"><constraints primaryKey="true"/></column>
            <column name="nombre" type="VARCHAR(255)"/>
            <column name="marca" type="VARCHAR(255)"/>
            <column name="precio" type="DOUBLE"/>
            <column name="stock" type="INT"/>
            <column name="categoria_id" type="BIGINT">
                <constraints foreignKeyName="fk_categoria" referencedTableName="categorias" referencedColumnNames="id"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="2" author="laganga3pelos">
        <insert tableName="categorias"><column name="id" value="1"/><column name="nombre" value="GPU"/></insert>
        <insert tableName="categorias"><column name="id" value="2"/><column name="nombre" value="CPU"/></insert>

        <insert tableName="componentes"><column name="nombre" value="RTX 4060"/><column name="marca" value="MSI"/><column name="precio" value="320000"/><column name="stock" value="15"/><column name="categoria_id" value="1"/></insert>
        <insert tableName="componentes"><column name="nombre" value="RTX 4070"/><column name="marca" value="ASUS"/><column name="precio" value="650000"/><column name="stock" value="10"/><column name="categoria_id" value="1"/></insert>
        <insert tableName="componentes"><column name="nombre" value="RX 7600"/><column name="marca" value="Gigabyte"/><column name="precio" value="290000"/><column name="stock" value="8"/><column name="categoria_id" value="1"/></insert>
        <insert tableName="componentes"><column name="nombre" value="RX 7800 XT"/><column name="marca" value="Sapphire"/><column name="precio" value="550000"/><column name="stock" value="12"/><column name="categoria_id" value="1"/></insert>
        <insert tableName="componentes"><column name="nombre" value="RTX 3060"/><column name="marca" value="Zotac"/><column name="precio" value="280000"/><column name="stock" value="20"/><column name="categoria_id" value="1"/></insert>
        
        <insert tableName="componentes"><column name="nombre" value="Ryzen 5 7600X"/><column name="marca" value="AMD"/><column name="precio" value="250000"/><column name="stock" value="20"/><column name="categoria_id" value="2"/></insert>
        <insert tableName="componentes"><column name="nombre" value="Core i5 13400F"/><column name="marca" value="Intel"/><column name="precio" value="210000"/><column name="stock" value="18"/><column name="categoria_id" value="2"/></insert>
    </changeSet>
    <!-- El resto de los componentes (30% restante) se carga vía DataLoader, ver config/DataLoader.java -->

</databaseChangeLog>